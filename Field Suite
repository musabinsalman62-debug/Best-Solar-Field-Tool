    function calc() {
        const m = document.getElementById('mode').value; const sIdx = document.getElementById('sysSize').value; const pT = parseFloat(document.getElementById('pnlType').value); const inv = document.getElementById('invSize').value; const bat = document.getElementById('bat').value; const bS = document.getElementById('batSize').value; const ph = document.getElementById('phase').value; const cT = document.getElementById('cabling').value;
        let tN = 0; let stc = 0; let dcD = 0; let epiD = 0; let sigD = 0;
        const epiP = parseFloat(document.getElementById('epiPerc').value);

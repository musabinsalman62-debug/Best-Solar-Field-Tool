        tN += (parseInt(document.getElementById('rcdQty').value) || 0) * 50; const multi = document.getElementById('multiExtras'); for (let o of multi.selectedOptions) { tN += parseInt(o.value); }
        if (epiP > 0) { epiD = ((globalKw + (m !== 'solar' ? parseFloat(bS) : 0)) * 1000 * 0.09) * epiP; tN -= epiD; }
        if (document.getElementById('signBtn').classList.contains('active')) { sigD = (m === 'both') ? 500 : 250; tN -= sigD; }
        document.getElementById('bookPrice').innerText = "$" + Math.round(tN + stc + sigD + epiD + dcD).toLocaleString();
        document.getElementById('netPrice').innerText = "$" + Math.round(tN).toLocaleString();
        document.getElementById('dcLabel').style.display = dcD > 0 ? 'block' : 'none'; document.getElementById('dcLabel').innerText = "DC COUPLE DISCOUNT: -$" + dcD.toLocaleString();
        document.getElementById('epiLabel').style.display = epiD > 0 ? 'block' : 'none'; document.getElementById('epiLabel').innerText = "ENVIRO PROTECTION INCENTIVE: -$" + Math.round(epiD).toLocaleString();
        document.getElementById('signLabel').style.display = sigD > 0 ? 'block' : 'none'; document.getElementById('signLabel').innerText = "SIGN ON DAY INCENTIVE: -$" + sigD.toLocaleString();
        globalWeekly = tN / 260; document.getElementById('weekPayment').innerText = "$" + globalWeekly.toFixed(2) + " / week"; runFinalComp();
    }
    recommend(); populateSolar(); syncUI();
</script>

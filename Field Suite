<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Best Solar & Batteries Official Field Tool</title>
    <style>
        :root { --blue: #1a73e8; --green: #34c759; --dark: #1c1c1e; --gold: #ffcc00; --sig-teal: #00ced1; --red: #ff3b30; --soft-blue: #e3f2fd; }
        body { font-family: -apple-system, sans-serif; background: #f2f2f7; margin: 0; padding: 10px; color: #1c1c1e; -webkit-tap-highlight-color: transparent; }
        .card { background: white; border-radius: 20px; padding: 18px; box-shadow: 0 8px 30px rgba(0,0,0,0.06); margin-bottom: 12px; }
        .row { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f2f2f7; }
        label { font-size: 11px; font-weight: 700; color: #8e8e93; text-transform: uppercase; letter-spacing: 0.5px; }
        select, input[type="number"] { padding: 12px; background: #f2f2f7; border: none; border-radius: 10px; font-size: 14px; font-weight: 600; box-sizing: border-box; width: 100%; margin-top: 5px; }
        input[type="number"] { width: 70px; text-align: center; margin-top: 0; }
        .section-title { font-size: 11px; font-weight: 800; color: var(--blue); margin: 15px 0 10px; text-transform: uppercase; }
        .extra-btn { background: #f2f2f7; border: 2px solid transparent; border-radius: 12px; padding: 12px 8px; font-size: 13px; font-weight: 600; text-align: center; transition: all 0.2s ease; color: #444; cursor: pointer; }
        .extra-btn.active { background: #eef6ff; border-color: var(--blue); color: var(--blue); box-shadow: 0 4px 12px rgba(0,122,255,0.15); }
        .extra-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 5px; }
        .multi-select { height: 160px; font-size: 11px; }
        .price-box { background: var(--dark); color: white; padding: 25px; border-radius: 20px; text-align: center; margin-top: 15px; }
        .strikethrough { font-size: 24px; color: #ff3b30; text-decoration: line-through; opacity: 0.8; font-weight: 700; margin-bottom: 5px; }
        .total-amt { font-size: 44px; font-weight: 800; color: var(--green); margin: 5px 0; }
        .disc-line { color: var(--sig-teal); font-weight: 800; font-size: 12px; margin: 4px 0; display: none; }
        .weekly { font-size: 20px; color: var(--gold); font-weight: 700; margin-top: 10px; }
        
        /* Dashboard Styles */
        .input-grid-sim { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 15px; }
        .sim-label { font-size: 8px; font-weight: 800; color: #8e8e93; text-transform: uppercase; display: block; margin-bottom: 4px; }
        .season-row { display: flex; gap: 8px; margin-bottom: 15px; }
        .s-btn { flex: 1; padding: 12px 5px; border-radius: 12px; border: 2px solid #f2f2f7; background: white; font-size: 10px; font-weight: 800; cursor: pointer; }
        .s-btn.active { border-color: var(--blue); background: var(--soft-blue); color: var(--blue); }
        .flow-section { background: var(--soft-blue); border-radius: 20px; padding: 20px 10px; margin-bottom: 12px; border: 1px solid #bbdefb; }
        .flow-title { font-size: 11px; font-weight: 900; color: var(--blue); text-transform: uppercase; text-align: center; margin-bottom: 20px; letter-spacing: 1px; }
        .linear-flow { display: flex; align-items: center; justify-content: space-between; position: relative; padding: 10px 0; }
        .node { text-align: center; flex: 1; z-index: 2; }
        .node .icon-box { background: white; width: 55px; height: 55px; border-radius: 15px; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; font-size: 30px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .node .val-sim { font-size: 12px; font-weight: 900; display: block; line-height: 1.1; }
        .node .lbl-sim { font-size: 8px; font-weight: 700; opacity: 0.6; text-transform: uppercase; margin-top: 3px; display: block; }
        .arrow-box { flex: 0.5; text-align: center; color: #ccc; font-size: 16px; transition: color 0.3s; font-weight: 900; }
        .arrow-box.active { color: var(--green); }
        .arrow-box.grid-in { color: #ff3b30; }
        .status-msg { text-align: center; font-size: 10px; font-weight: 800; margin-top: 10px; }
        .fin-row-sim { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #f2f2f7; font-size: 12px; font-weight: 700; }
        .banner-sim { background: var(--dark); color: white; border-radius: 20px; padding: 18px; text-align: center; margin-top: 10px; }

        /* CLOSING ENGINE STYLES */
        .closer-card { background: var(--dark); border-radius: 25px; padding: 25px; margin-top: 20px; color: white; text-align: center; border: 2px solid var(--blue); }
        .choice-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }
        .choice-btn { padding: 20px; border-radius: 18px; border: none; font-weight: 900; font-size: 14px; cursor: pointer; text-transform: uppercase; transition: all 0.2s; }
        .btn-yes { background: var(--green); color: white; box-shadow: 0 4px 15px rgba(52, 199, 89, 0.4); }
        .btn-no { background: #333; color: #8e8e93; }
        .feedback-area { display: none; margin-top: 25px; padding-top: 25px; border-top: 1px solid #333; text-align: left; animation: fadeIn 0.4s ease; }
        .objection-btn { background: #2c2c2e; color: #fff; padding: 14px; border-radius: 12px; margin-bottom: 10px; font-size: 12px; font-weight: 700; border: 1px solid #444; width: 100%; text-align: left; }
        .rebuttal-box { background: #e3f2fd; color: var(--dark); padding: 15px; border-radius: 12px; font-size: 12px; line-height: 1.4; margin: 10px 0 20px; display: none; font-weight: 700; border-left: 5px solid var(--blue); }
        .final-cta { background: var(--blue); color: white; padding: 22px; border-radius: 15px; width: 100%; font-weight: 900; font-size: 16px; border: none; margin-top: 15px; cursor: pointer; box-shadow: 0 4px 15px rgba(26, 115, 232, 0.4); }
        .secondary-cta { background: none; border: 2px solid #444; color: #8e8e93; padding: 15px; border-radius: 15px; width: 100%; font-weight: 800; font-size: 12px; margin-top: 10px; cursor: pointer; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .comp-card { background: #fff; border-radius: 25px; padding: 25px; border: 3px solid var(--blue); margin-top: 20px; }
        .comp-title { font-weight: 900; font-size: 16px; text-align: center; margin-bottom: 20px; color: var(--blue); }
        .comp-split { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; text-align: center; margin-bottom: 20px; }
        .comp-box { background: #f8f9fa; padding: 15px; border-radius: 15px; }
        .comp-lbl { font-size: 9px; font-weight: 800; color: #8e8e93; text-transform: uppercase; margin-bottom: 8px; }
        .comp-val { font-size: 20px; font-weight: 900; color: var(--dark); }
        .habit-swap-future { background: #f0fff4; border-radius: 20px; padding: 20px; text-align: center; border: 1px solid var(--green); margin-top: 15px; display: none; }
        .eb-stat-box { background: var(--soft-blue); padding: 15px; border-radius: 15px; border-left: 5px solid var(--blue); margin-bottom: 10px; }
        .eb-gain-amt { color: var(--green); font-size: 32px; font-weight: 900; display: block; margin-top: 5px; }
        .v-card { background: #fff; border-radius: 20px; padding: 20px; border: 1px solid #e5e5ea; margin-top: 12px; }
        .v-gen-btn { background: var(--blue); color: white; border: none; padding: 16px; border-radius: 12px; width: 100%; font-weight: 800; font-size: 14px; cursor: pointer; }
        .v-table { width: 100%; font-size: 12px; border-collapse: collapse; }
        .v-table td { padding: 10px 0; border-bottom: 1px solid #f2f2f7; font-weight: 600; }
        .v-val { text-align: right; color: var(--red); font-weight: 800; }
        .v-total-box { background: var(--dark); color: white; padding: 20px; border-radius: 15px; text-align: center; margin: 15px 0; }
        .v-total-amt { font-size: 32px; font-weight: 900; color: var(--red); display: block; }
        .v-checklist { width: 100%; border-collapse: collapse; margin-top: 15px; }
        .v-checklist th { font-size: 9px; text-transform: uppercase; color: #8e8e93; padding-bottom: 8px; border-bottom: 2px solid #f2f2f7; }
        .v-checklist td { padding: 10px 0; font-size: 11px; font-weight: 700; border-bottom: 1px solid #f2f2f7; }
        .v-check { color: var(--green); text-align: center; font-weight: 900; }
        .v-cross { color: var(--red); text-align: center; font-weight: 900; }
        .v-rank-bar { background: #f2f2f7; padding: 10px; border-radius: 12px; display: flex; justify-content: space-around; margin-top: 15px; }
        .v-rank-item { font-size: 8px; font-weight: 800; text-align: center; line-height: 1.2; color: #444; }
        .stamp { text-align: center; font-size: 9px; font-weight: 800; color: #c1c1c1; margin-top: 20px; text-transform: uppercase; border-top: 1px solid #e5e5e5; padding-top: 10px; }
    </style>
</head>
<body>

<div class="card">
    <div style="text-align:center; margin-bottom:15px; font-weight:900; font-size:18px;">ENERGY FLOW DASHBOARD</div>
    <div class="input-grid-sim">
        <div><label class="sim-label">Daily Use</label><input type="number" id="simUsage" value="20" oninput="recommend()"></div>
        <div><label class="sim-label">Night %</label><input type="number" id="simNight" value="60" oninput="recommend()"></div>
        <div><label class="sim-label">Solar kW</label><input type="number" id="simKw" value="10.45" step="0.05" oninput="sim()"></div>
        <div><label class="sim-label">Bat kWh</label><input type="number" id="simBat" value="10" step="1" oninput="sim()"></div>
        <div><label class="sim-label">FiT ($)</label><input type="number" id="simFit" value="0.08" step="0.01" oninput="sim()"></div>
        <div><label class="sim-label">Import Rate</label><input type="number" id="simRate" value="0.38" step="0.01" oninput="sim()"></div>
        <div style="grid-column: span 3; margin-top:5px;"><label class="sim-label">Daily Supply Charge ($)</label><input type="number" id="simSupply" value="1.15" step="0.01" oninput="sim()"></div>
    </div>
    <div class="season-row">
        <button class="s-btn active" id="btn-winter" onclick="setSeason('winter', 2.5)">WINTER</button>
        <button class="s-btn" id="btn-spring" onclick="setSeason('spring', 4.5)">SPRING/AUT</button>
        <button class="s-btn" id="btn-summer" onclick="setSeason('summer', 6.0)">SUMMER</button>
    </div>
    <div class="flow-section">
        <div class="flow-title">Daytime: Direct Power Sequence</div>
        <div class="linear-flow">
            <div class="node"><div class="icon-box">☀️</div><span class="val-sim" id="sdSolar">0.0k</span><span class="lbl-sim">Solar</span></div>
            <div class="arrow-box active" id="aSun">▶</div>
            <div class="node"><div class="icon-box">🏠</div><span class="val-sim" id="sdHome">0.0k</span><span class="lbl-sim">House</span></div>
            <div class="arrow-box" id="aBat">▶</div>
            <div class="node"><div class="icon-box">🔋</div><span class="val-sim" id="sdBat">0k / 0%</span><span class="lbl-sim">Battery</span></div>
            <div class="arrow-box" id="aGrid">▶</div>
            <div class="node"><div class="icon-box">🌐</div><span class="val-sim" id="sdGrid">0.0k</span><span class="lbl-sim">Grid</span></div>
        </div>
        <div class="status-msg" id="dStatus">STATUS: STABLE</div>
    </div>
    <div class="flow-section">
        <div class="flow-title">Nighttime Utilization</div>
        <div class="linear-flow">
            <div class="node"><div class="icon-box">🌐</div><span class="val-sim" id="snGrid">0.0k</span><span class="lbl-sim">Grid</span></div>
            <div class="arrow-box" id="aGridIn">▶</div>
            <div class="node"><div class="icon-box">🏠</div><span class="val-sim" id="snHome">0.0k</span><span class="lbl-sim">House</span></div>
            <div class="arrow-box" id="aBatOut">◀</div>
            <div class="node"><div class="icon-box">🔋</div><span class="val-sim" id="snBat">0.0k</span><span class="lbl-sim">Battery</span></div>
        </div>
        <div class="status-msg" id="nStatus">STATUS: BATTERY ACTIVE</div>
    </div>
    <div class="fin-row-sim"><span>Daily Solar Credits</span><span style="color:var(--green)" id="sfCredits">+$0.00</span></div>
    <div class="fin-row-sim"><span>Daily Supply + Shortfall</span><span style="color:#ff3b30" id="sfCosts">-$0.00</span></div>
    <div class="fin-row-sim"><span>Daily Net Total</span><span id="sfNet">-$0.00</span></div>
    <div class="banner-sim">
        <div style="font-size:9px; opacity:0.7; margin-bottom:5px;">≈ ESTIMATED MONTHLY BILL</div>
        <div style="font-size:32px; font-weight:900;" id="mBillSim">$0.00</div>
    </div>
</div>

<div class="card">
    <div style="font-weight: 900; font-size: 18px; text-align: center; margin-bottom: 15px;">BEST SOLAR & BATTERIES</div>
    <label>Sales Mode</label>
    <select id="mode" onchange="syncUI()" style="margin-bottom:15px;"><option value="both">Solar + Battery</option><option value="solar">Solar Only</option><option value="battery">Battery Only</option></select>
    <div id="solarInputs">
        <label>System Size</label><select id="sysSize" onchange="calc()" style="margin-bottom:15px;"></select>
        <label>Panel Upgrade</label><select id="pnlType" onchange="calc()"><option value="0">Risen 475W</option><option value="0.05">Jinko 510</option><option value="0.09">Aiko 465</option><option value="0.10">Aiko 475</option></select>
    </div>
    <div id="batInputs">
        <div style="display:flex; gap:10px; margin-top:15px;"><div style="flex:1"><label>Phase</label><select id="phase" onchange="syncInverters()"><option value="1">1P</option><option value="3">3P</option></select></div><div style="flex:1"><label>Hardware</label><select id="bat" onchange="syncInverters()"><option value="sig">SigEnergy</option><option value="goodwe">GoodWe</option><option value="alpha">Alpha</option></select></div></div>
        <label style="margin-top:15px; display:block;">Inverter Size</label><select id="invSize" onchange="syncBatteries()"></select>
        <label style="margin-top:15px; display:block;">Battery Capacity</label><select id="batSize" onchange="calc()"></select>
        <label style="margin-top:15px; display:block;">Cabling Distance</label><select id="cabling" onchange="calc()"></select>
    </div>
</div>

<div class="card" id="roofSection">
    <div class="section-title">Roof Essentials</div>
    <div class="row"><span>Tile Roof ($20)</span><input type="number" class="roof-qty" data-cost="20" value="0" oninput="calc()"></div>
    <div class="row"><span>Spanish Tiles ($40)</span><input type="number" class="roof-qty" data-cost="40" value="0" oninput="calc()"></div>
    <div class="row"><span>Two Storey ($20)</span><input type="number" class="roof-qty" data-cost="20" value="0" oninput="calc()"></div>
    <div class="row"><span>Removal ($40)</span><input type="number" class="roof-qty" data-cost="40" value="0" oninput="calc()"></div>
    <div class="row"><span>Landscape ($20)</span><input type="number" class="roof-qty" data-cost="20" value="0" oninput="calc()"></div>
    <div class="row"><span>Kliplock ($40)</span><input type="number" class="roof-qty" data-cost="40" value="0" oninput="calc()"></div>
    <div class="row"><span>Pitch 25-34° ($40)</span><input type="number" class="roof-qty" data-cost="40" value="0" oninput="calc()"></div>
    <div class="row"><span>Optimisers ($100 ea)</span><input type="number" id="optiQty" value="0" oninput="calc()"></div>
</div>

<div class="card">
    <div class="section-title">Project Extras</div>
    <select id="multiExtras" class="multi-select" multiple onchange="calc()">
        <optgroup label="Infrastructure"><option value="100">Meter Isolator - $100</option><option value="100">Switch Enclosure - $100</option><option value="250">External Sub board 1P - $250</option><option value="500">External Sub board 3P - $500</option><option value="700">Internal Sub board - $700</option><option value="250">Surge Protection 1P - $250</option><option value="500">No Main Switch 1P - $500</option><option value="3000">No Main Switch 3P - $3000</option><option value="1500">Meter Board (Asbestos) - $1500</option><option value="5000">Full Meter Box Replacement - $5000</option></optgroup>
        <optgroup label="Monitoring & Export"><option value="100">1P Fixed Export - $100</option><option value="300">3P Fixed Export - $300</option><option value="300">1P Flexible Export - $300</option><option value="600">2P Flexible Export - $600</option><option value="500">1P HK1000 Consumption - $500</option><option value="500">3P HK3000 Consumption - $500</option><option value="500">2P Alpha DTSU Meter - $500</option><option value="250">SIG Power Meter 1P - $250</option><option value="500">SIG Power Meter 3P - $500</option><option value="200">SIG Sub1G Transmitter - $200</option><option value="1500">1P Existing Catchpower - $1500</option><option value="1750">3P Existing Catchpower - $1750</option></optgroup>
        <optgroup label="Height & Travel"><option value="850">EWP 13kw/Day - $850</option><option value="1300">Cherry Picker - $1300</option><option value="1000">Height Split (Single/Two) - $1000</option><option value="1000">Catenary Wire (5m) - $1000</option><option value="1500">Catenary Wire (10m) - $1500</option><option value="1000">Travel 100-200km - $1000</option><option value="3000">Travel 200-300km - $3000</option><option value="5000">Travel 300-500km - $5000</option></optgroup>
        <optgroup label="Specialized Extras"><option value="200">Alpha Switch - $200</option><option value="200">2x Bollards - $200</option><option value="200">Cement Sheet - $200</option><option value="200">Form Ply - $200</option><option value="300">Site Visit - $300</option><option value="300">Hot Water Timer - $300</option><option value="500">Battery Removal (Keep) - $500</option><option value="1000">Battery Removal (Full) - $1000</option></optgroup>
    </select>
    <div class="row" style="margin-top:10px;"><span>RCD Type A ($50 ea)</span><input type="number" id="rcdQty" value="0" oninput="calc()"></div>
</div>

<div class="card">
    <div class="section-title">EXCLUSIVE PROMOTIONS</div>
    <label>ENVIRONMENT PROTECTION INCENTIVE</label>
    <select id="epiPerc" onchange="calc()" style="margin-bottom:12px;"><option value="0">None Applied</option><option value="0.10">10%</option><option value="0.20">20%</option><option value="0.30">30%</option><option value="0.40">40%</option><option value="0.50">50%</option><option value="0.60">60%</option><option value="0.70">70%</option><option value="0.80">80% (Max)</option></select>
    <div class="extra-grid"><div id="signBtn" class="extra-btn" style="grid-column: span 2;" onclick="toggleBtn(this)">Sign on Day Incentive</div></div>
</div>

<div class="price-box">
    <div id="bookPrice" class="strikethrough">$0</div><div class="total-amt" id="netPrice">$0</div>
    <div class="disc-line" id="dcLabel">DC COUPLE DISCOUNT: -$0</div>
    <div class="disc-line" id="epiLabel">ENVIRO PROTECTION INCENTIVE: -$0</div>
    <div class="disc-line" id="signLabel">SIGN ON DAY INCENTIVE: -$0</div>
    <div class="weekly" id="weekPayment">$0.00 / week</div>
</div>

<div class="v-card">
    <div style="text-align:center; margin-bottom:20px;"><span style="font-weight:900; font-size:16px;">VALUE GUARDIAN ANALYSIS</span></div>
    <button class="v-gen-btn" onclick="vReveal()">GENERATE RISK COMPARISON</button>
    <div id="analysisResult" style="display:none; margin-top:15px;">
        <table class="v-table">
            <tr><td>Service Savings (10yr Warranty)</td><td class="v-val">-$2,700</td></tr>
            <tr><td>Compliance & Rectification Risk</td><td class="v-val">-$1,450</td></tr>
            <tr><td>Wait-Time Production Loss</td><td class="v-val" id="vWaitLoss">-$0</td></tr>
        </table>
        <div class="v-total-box"><span style="font-size:9px; opacity:0.8;">Total Liability in Standard Quotes</span><span class="v-total-amt" id="vTotalRisk">$0</span></div>
        <table class="v-checklist">
            <thead><tr><th align="left">Standard of Care</th><th>BEST SOLAR</th><th>STANDARD</th></tr></thead>
            <tbody>
                <tr><td>In-House SAA Installers</td><td class="v-check">✓</td><td class="v-cross">✕</td></tr>
                <tr><td>Dual License (Builder+Elec)</td><td class="v-check">✓</td><td class="v-cross">✕</td></tr>
                <tr><td>24-48hr Tech Response</td><td class="v-check">✓</td><td class="v-cross">✕</td></tr>
            </tbody>
        </table>
        <div class="v-rank-bar">
            <div class="v-rank-item">#1 BATTERY<br>INSTALLER SA</div>
            <div class="v-rank-item">#2 SOLAR<br>INSTALLER SA</div>
            <div class="v-rank-item">700+ GOOGLE<br>REVIEWS</div>
        </div>
    </div>
</div>

<div class="comp-card">
    <div class="comp-title">NOW VS FUTURE WEEKLY OUTGOINGS</div>
    <div style="margin-bottom: 20px;"><label>Current Yearly Power Bill ($)</label><input type="number" id="yearlyBill" value="2400" oninput="runFinalComp()"></div>
    <div class="comp-split">
        <div class="comp-box"><div class="comp-lbl">Status Quo</div><div class="comp-val" id="nowWeek">$0.00</div><div class="comp-sub">per week (Bills only)</div></div>
        <div class="comp-box" style="border: 2px solid var(--blue);"><div class="comp-lbl">With Best Solar</div><div class="comp-val" id="futureWeek">$0.00</div><div class="comp-sub">per week (System + Bills)</div></div>
    </div>
    <div id="habitSwapFuture" class="habit-swap-future">
        <div style="font-size: 11px; font-weight: 800; color: var(--blue); margin-bottom: 10px;">LIFESTYLE DIFFERENCE</div>
        <div style="display: flex; justify-content: space-around;">
            <div><span id="fCoffee" style="font-size: 24px; font-weight: 900;">0.0</span><span class="lbl-sim">Coffees</span></div>
            <div><span id="fBeer" style="font-size: 24px; font-weight: 900;">0.0</span><span class="lbl-sim">Pints</span></div>
        </div>
    </div>
</div>

<div class="card" style="border-top: 5px solid var(--green); margin-top: 20px;">
    <div class="eb-title">PROPERTY EQUITY BRIDGE</div>
    <div style="margin-bottom: 20px;"><label>EST. CURRENT HOME VALUE ($)</label><input type="number" id="homeVal" value="750000" oninput="runFinalComp()"></div>
    <div class="comp-split">
        <div class="comp-box"><div class="comp-lbl">Today's Value</div><div class="comp-val" id="valToday">$750,000</div></div>

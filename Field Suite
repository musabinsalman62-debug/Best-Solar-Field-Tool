        const u = parseFloat(document.getElementById('simUsage').value) || 0; const nP = parseFloat(document.getElementById('simNight').value) / 100; const kw = parseFloat(document.getElementById('simKw').value) || 0; const batS = parseFloat(document.getElementById('simBat').value) || 1; const fit = parseFloat(document.getElementById('simFit').value) || 0; const supply = parseFloat(document.getElementById('simSupply').value) || 0; const rate = parseFloat(document.getElementById('simRate').value) || 0.38;
        const dL = u * (1 - nP); const nL = u * nP; const gen = kw * sunH;
        let ext = gen - dL; let dI = ext < 0 ? Math.abs(ext) : 0; let st = Math.min(Math.max(0, ext), batS); let exK = Math.max(0, ext - st); let nB = Math.min(nL, st); let nI = Math.max(0, nL - st);
        document.getElementById('sdSolar').innerText = gen.toFixed(1) + "k"; document.getElementById('sdHome').innerText = dL.toFixed(1) + "k"; document.getElementById('sdBat').innerText = st.toFixed(1) + "k / " + Math.round((st/batS)*100) + "%"; document.getElementById('sdGrid').innerText = exK.toFixed(1) + "k";

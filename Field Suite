    function recommend() { const u = parseFloat(document.getElementById('simUsage').value) || 0; const n = parseFloat(document.getElementById('simNight').value) / 100; document.getElementById('simKw').value = (u * 0.52).toFixed(2); document.getElementById('simBat').value = Math.ceil(u * n); sim(); }
    function setSeason(s, h) { sunH = h; document.querySelectorAll('.s-btn').forEach(b => b.classList.remove('active')); document.getElementById('btn-' + s).classList.add('active'); sim(); }

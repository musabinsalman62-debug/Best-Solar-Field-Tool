    function populateSolar() { const sys = document.getElementById('sysSize'); SOLAR.forEach((s, idx) => sys.add(new Option(`${s.kw} kW - Book: $${s.inv.toLocaleString()}`, idx))); }
    function syncInverters() { const ph = document.getElementById('phase').value; const bat = document.getElementById('bat').value; const inv = document.getElementById('invSize'); const cur = inv.value; inv.innerHTML = ""; const iS = (bat === 'alpha') ? [5] : (ph === "1" ? Object.keys(PB[bat+'_1p']) : Object.keys(PB[bat+'_3p'])); iS.forEach(s => inv.add(new Option(s + "kW Inverter", s))); if(iS.includes(cur)) inv.value = cur; const cab = document.getElementById('cabling'); cab.innerHTML = ""; const cD = (bat === 'goodwe') ? PB.cable_gw : PB.cable_std; cab.add(new Option("0-10m Standard", "free")); cab.add(new Option(`10-20m ($${cD.tier1})`, "tier1")); cab.add(new Option(`20-30m ($${cD.tier2})`, "tier2")); cab.add(new Option(`30-40m ($${cD.tier3})`, "tier3")); syncBatteries(); }
